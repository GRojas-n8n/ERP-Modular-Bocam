{
  "name": "@bocam/ventas",
  "version": "1.0.0",
  "description": "Módulo de Ventas (Clientes, Cotizaciones y Facturación operativa)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --transpile-only src/main.ts",
    "dev:index": "ts-node-dev --transpile-only src/index.ts",
    "tunnel": "npx --yes localtunnel --port 3012 --subdomain bocam-ventas || npx --yes localtunnel --port 3012",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts",
    "test:db": "ts-node src/test-db.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "amqplib": "^0.10.3",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "redis": "^4.6.7",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.1",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "@types/uuid": "^9.0.2",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
