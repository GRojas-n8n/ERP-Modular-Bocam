{
  "name": "@bocam/control-obra",
  "version": "1.0.0",
  "description": "Módulo de Control de Obra (Bitácoras, Avances Físicos, Estimaciones)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --transpile-only src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts",
    "test:integration:finanzas-pago-feedback": "node -r ts-node/register/transpile-only test/integration/finanzas.pago-registrado.integration.test.ts",
    "test:e2e:reconciliacion": "node -r ts-node/register/transpile-only test/e2e/reconciliacion.e2e.test.ts",
    "test:e2e:seguridad": "node -r ts-node/register/transpile-only test/e2e/seguridad.e2e.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "amqplib": "^0.10.3",
    "axios": "^1.15.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "redis": "^4.6.7",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.1",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.2",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
}
