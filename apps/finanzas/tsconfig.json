{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "../../packages/auth-middleware/src/**/*", "../../packages/event-bus/src/**/*", "../../packages/observability/src/**/*", "../../packages/tenant-idempotency/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
