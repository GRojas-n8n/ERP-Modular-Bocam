# ---------------------------------------------------------------------------
# BOCAM ERP - Plantilla de entorno para QNAP TS-832PX (preproduccion interna)
# Copiar a .env.qnap y rellenar valores reales.
# ---------------------------------------------------------------------------

NODE_ENV=production

# Base de datos
DB_USER=bocam_admin
DB_PASSWORD=CAMBIA_ESTE_PASSWORD
DB_NAME=bocam_erp_qnap
DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap

# URLs especificas por modulo (mismo cluster PostgreSQL en esta fase)
AUTH_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
COMPRAS_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
FINANZAS_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
CONTROL_OBRA_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
CONTABILIDAD_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
PERSONAL_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
SEGURIDAD_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap
GERENCIA_TECNICA_DATABASE_URL=postgresql://bocam_admin:CAMBIA_ESTE_PASSWORD@postgres:5432/bocam_erp_qnap

# Mensajeria y cache
RMQ_USER=bocam_broker
RMQ_PASSWORD=CAMBIA_ESTE_PASSWORD
RABBITMQ_URL=amqp://bocam_broker:CAMBIA_ESTE_PASSWORD@rabbitmq:5672
REDIS_URL=redis://redis:6379

# Seguridad
JWT_SECRET=CAMBIA_ESTE_JWT_SECRET

# Integraciones / Contabilidad
CONTABILIDAD_BASE_URL=http://contabilidad:3008
SAT_CALLBACK_SHARED_SECRET=CAMBIA_ESTE_SECRETO
SAT_ADAPTER_BASE_URL=https://sat-adapter-interno.local
SAT_ADAPTER_API_KEY=CAMBIA_ESTA_API_KEY
SAT_ADAPTER_TIMEOUT_MS=6000
SAT_WORKER_RETRY_DELAY_MS=1500
SAT_WORKER_MAX_ATTEMPTS=3

# Publicacion shell
QNAP_APP_PORT=18080

